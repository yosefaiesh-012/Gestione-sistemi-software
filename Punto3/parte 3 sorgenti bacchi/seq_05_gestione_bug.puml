@startuml Sequenza_Gestione_Bug
!theme plain
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #4A7C9B
skinparam sequenceLifeLineBorderColor #4A7C9B

title Gestione Bug - Segnalazione, Assegnazione e Risoluzione

actor Sviluppatore as Dev
participant ":HomeSviluppatore" as HS #E8F5E9
participant ":ViewSegnalazioneBug" as VSB #E8F5E9
participant ":ViewDettaglioBug" as VDB #E8F5E9
participant ":ViewModificaBug" as VMB #E8F5E9
participant ":GestioneBugDevController" as GBDC #E3F2FD
participant ":Bug" as B #F5F8FA

== Segnalazione Bug ==

Dev -> HS : seleziona un task e sceglie "Segnala Bug"
HS -> VSB : mostra ViewSegnalazioneBug
Dev -> VSB : inserisce nome, descrizione, priorità
Dev -> VSB : (opzionale) associa il bug a un task
VSB -> GBDC : segnalaBug(nome, descrizione,\npriorita, taskAssociato)

alt Dati validi
  create B
  GBDC -> B : crea()
  B --> GBDC : return bugId
  GBDC --> VSB : return {esito: ok, bugId}
  VSB -> VDB : redirect -> ViewDettaglioBug

else Dati mancanti o non validi
  GBDC --> VSB : return {esito: errore,\nmsg: "Dati non validi"}
  VSB --> Dev : mostra errori di validazione

else Bug duplicato rilevato
  GBDC --> VSB : return {esito: warning,\nmsg: "Possibile duplicato rilevato"}
  VSB --> Dev : mostra avviso duplicato,\nchiede conferma
end

== Risoluzione Bug ==

Dev -> HS : apre bug assegnato
HS -> VDB : mostra ViewDettaglioBug
Dev -> VMB : aggiorna stato bug a "Risolto"
VMB -> GBDC : aggiornaStato(bugId, "Risolto")

alt Transizione di stato valida
  GBDC -> B : setStato("Risolto")
  GBDC -> B : registraStoricoModifiche()
  B --> GBDC : ok
  GBDC --> VMB : return {esito: ok}
  VMB --> Dev : bug marcato come risolto,\nin attesa di verifica tester

else Transizione di stato non consentita
  GBDC --> VMB : return {esito: errore,\nmsg: "Transizione non valida"}
  VMB --> Dev : mostra errore
end

@enduml
